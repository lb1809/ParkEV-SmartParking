<mxfile>
  <diagram name="ParkEV Simple Architecture">
    <mxGraphModel dx="1200" dy="900" grid="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="T" value="ParkEV — System Architecture" style="text;fontSize=20;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="400" height="30" as="geometry"/>
        </mxCell>

        <!-- USER -->
        <mxCell id="U" value="User&#xa;(Phone / Laptop)" style="shape=mxgraph.basic.smiley;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="70" width="80" height="70" as="geometry"/>
        </mxCell>

        <!-- FRONTEND -->
        <mxCell id="F" value="Frontend&#xa;(HTML / CSS / JavaScript)&#xa;Login | Register | Dashboard | Admin" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="180" width="320" height="60" as="geometry"/>
        </mxCell>

        <!-- SECURITY -->
        <mxCell id="S" value="Security Layer&#xa;JWT + CORS + Helmet + Rate Limit" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="290" width="320" height="50" as="geometry"/>
        </mxCell>

        <!-- BACKEND -->
        <mxCell id="B" value="Node.js + Express Backend&#xa;Auth | Slots | Bookings | Admin | EV Calculator" style="rounded=1;whiteSpace=wrap;fillColor=#2c3e50;strokeColor=#34495e;fontColor=#fff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="390" width="400" height="60" as="geometry"/>
        </mxCell>

        <!-- LOCAL DB -->
        <mxCell id="D" value="Local Cache&#xa;(data.json)&#xa;0ms Speed" style="shape=cylinder3;size=10;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="510" width="130" height="80" as="geometry"/>
        </mxCell>

        <!-- SYNC ENGINE -->
        <mxCell id="SE" value="Cloud Sync&#xa;Engine&#xa;(Every 5s)" style="ellipse;whiteSpace=wrap;fillColor=#27ae60;strokeColor=#1a7a3e;fontColor=#fff;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="520" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- AWS -->
        <mxCell id="AWS" value="AWS DynamoDB&#xa;(Cloud Database)" style="shape=cylinder3;size=10;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="510" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- FIREBASE -->
        <mxCell id="FB" value="Google Firebase&#xa;(Sign-In Auth)" style="shape=cylinder3;size=10;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="370" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- YOLO + CAMERA -->
        <mxCell id="CAM" value="CCTV Camera" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="280" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="YO" value="YOLOv8&#xa;Detection" style="rounded=1;whiteSpace=wrap;fillColor=#e74c3c;strokeColor=#b85450;fontColor=#fff;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="360" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- ARROWS -->
        <mxCell id="a1" style="strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="U" target="F" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a2" style="strokeWidth=2;strokeColor=#d6b656;" edge="1" source="F" target="S" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a3" style="strokeWidth=2;strokeColor=#34495e;" edge="1" source="S" target="B" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a4" style="strokeWidth=2;strokeColor=#82b366;" edge="1" source="B" target="D" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a5" style="strokeWidth=2;strokeColor=#27ae60;" edge="1" source="D" target="SE" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a6" value="Sync" style="strokeWidth=2;strokeColor=#9673a6;fontStyle=1;" edge="1" source="SE" target="AWS" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a7" value="Verify Token" style="strokeWidth=2;strokeColor=#b85450;fontStyle=1;" edge="1" source="B" target="FB" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a8" style="strokeWidth=2;strokeColor=#b85450;" edge="1" source="CAM" target="YO" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a9" value="Slot Status" style="strokeWidth=2;strokeColor=#b85450;fontStyle=1;" edge="1" source="YO" target="B" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
